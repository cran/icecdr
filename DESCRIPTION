Package: icecdr
Type: Package
Title: Download Sea Ice Concentration Data from the NSIDC Climate Data
        Record
Version: 1.0.0
Authors@R: person("Elio", "Campitelli", , "eliocampitelli@gmail.com", role = c("cre", "aut", "cph"),
